{
  "name": "gumes-shoes",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:css\" \"npm:dev:server\"",
    "dev:server": "node --watch server.js",
    "dev:css": "tailwindcss -i src/styles/input.css -o public/css/main.css --watch",
    "build:css": "tailwindcss -i src/styles/input.css -o public/css/main.css --minify",
    "start": "node server.js",
    "db:init": "node db/init.js",
    "db:seed": "node db/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "busboy": "^1.6.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "express-session": "^1.18.1",
    "pg": "^8.13.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.0"
  }
}
