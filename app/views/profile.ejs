<%- include('partials/head', { title: title }) %>
<%- include('partials/navbar') %>

<main class="pt-56 pb-24 px-6 md:px-12 max-w-5xl mx-auto min-h-screen">
  <header class="mb-16">
    <h1 class="font-[family-name:var(--font-headline)] text-5xl font-light tracking-tight">Your Profile</h1>
    <p class="mt-4 text-sm tracking-[0.2em] uppercase text-outline">Digital Curator Member</p>
  </header>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
    <div class="space-y-8">
      <div class="bg-surface-container-lowest p-8 text-center border border-outline-variant/30 shadow-md">
        <div class="w-20 h-20 burnished-gradient mx-auto flex items-center justify-center mb-4 rounded-full">
          <span class="text-on-primary font-[family-name:var(--font-headline)] text-2xl font-bold">
            <%= ((user.name || user.email).slice(0,2)).toUpperCase() %>
          </span>
        </div>
        <h2 class="font-[family-name:var(--font-headline)] text-xl font-bold"><%= user.name || 'Curator' %></h2>
        <p class="text-xs text-outline mt-1"><%= user.email %></p>
        <% if (user.is_admin) { %>
          <div class="mt-6 pt-6 border-t border-outline-variant/10">
            <p class="text-[10px] uppercase tracking-widest text-primary mb-1">Admin Access</p>
            <a href="/admin" class="text-[11px] uppercase tracking-widest text-primary-container border-b border-primary-container">Open Admin Panel</a>
          </div>
        <% } %>
      </div>
      <nav class="space-y-2">
        <a href="/orders" class="flex items-center gap-4 p-4 hover:bg-surface-container transition-colors group">
          <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors">shopping_bag</span>
          <span class="text-sm uppercase tracking-widest">Order History</span>
        </a>
        <button type="button" data-logout class="flex items-center gap-4 p-4 hover:bg-surface-container transition-colors group w-full text-left">
          <span class="material-symbols-outlined text-outline group-hover:text-primary transition-colors">logout</span>
          <span class="text-sm uppercase tracking-widest">Sign Out</span>
        </button>
      </nav>
    </div>

    <div class="lg:col-span-2 space-y-12">
      <section class="bg-surface-container-lowest p-8 md:p-12 border border-outline-variant/30 shadow-md">
        <h3 class="font-[family-name:var(--font-headline)] text-xl mb-8 flex items-center gap-3">
          <span class="material-symbols-outlined text-primary">person</span>
          Personal Information
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-outline mb-2">Full Name</label>
            <input class="w-full bg-transparent border-0 border-b border-outline-variant focus:outline-none focus:border-primary py-3 px-0" value="<%= user.name || '' %>" readonly />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-outline mb-2">Email</label>
            <input class="w-full bg-transparent border-0 border-b border-outline-variant focus:outline-none focus:border-primary py-3 px-0" value="<%= user.email %>" readonly />
          </div>
        </div>
        <p class="text-[10px] text-outline uppercase tracking-widest mt-8">
          <span class="material-symbols-outlined text-base align-middle">lock</span>
          Edit profile akan dirilis di update berikutnya.
        </p>
      </section>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot', { pageScript: '/js/auth.js' }) %>
