<%- include('partials/head', { title: title }) %>
<%- include('partials/navbar') %>

<main class="pt-48 pb-32 px-6 md:px-12 max-w-screen-xl mx-auto min-h-screen">
  <header class="mb-14">
    <p class="text-primary text-xs tracking-[0.3em] uppercase mb-3">Your Selection</p>
    <h1 class="font-[family-name:var(--font-headline)] text-5xl md:text-6xl font-light tracking-tight">Shopping Cart</h1>
    <p id="cart-count-text" class="mt-3 text-sm tracking-[0.2em] uppercase text-outline hidden"></p>
  </header>

  <!-- Empty state -->
  <div id="cart-empty" class="hidden flex-col items-center justify-center py-32 text-center">
    <span class="material-symbols-outlined text-outline-variant mb-6" style="font-size:64px;font-variation-settings:'FILL' 0,'wght' 100">shopping_bag</span>
    <h2 class="font-[family-name:var(--font-headline)] text-3xl mb-3">Your cart is empty</h2>
    <p class="text-on-surface-variant text-sm mb-10 max-w-xs">Explore our collection and add a piece to your selection.</p>
    <a href="/" class="burnished-gradient text-on-primary text-[11px] font-bold tracking-widest uppercase px-10 py-4 hover:brightness-110 transition-all">Browse Collection</a>
  </div>

  <!-- Items + summary -->
  <div id="cart-content" class="hidden grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-start">
    <div class="lg:col-span-7 xl:col-span-8">
      <div id="cart-items" class="divide-y divide-outline-variant/10"></div>
      <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center pt-8 gap-4 border-t border-outline-variant/10">
        <a href="/" class="flex items-center gap-2 text-[11px] uppercase tracking-[0.2em] text-outline hover:text-primary-container transition-all group">
          <span class="material-symbols-outlined text-base group-hover:-translate-x-1 transition-transform">arrow_right_alt</span>
          Continue Shopping
        </a>
        <div class="flex items-center gap-4 text-[11px] uppercase tracking-[0.2em]">
          <span class="text-outline">Need assistance?</span>
          <a href="/contact" class="text-on-surface border-b border-outline-variant hover:border-primary-container hover:text-primary-container transition-all">Contact Atelier</a>
        </div>
      </div>
    </div>

    <aside class="lg:col-span-5 xl:col-span-4 lg:sticky lg:top-48">
      <div class="bg-surface-container-lowest border border-outline-variant/30 shadow-md">
        <div class="px-8 pt-8 pb-6 border-b border-outline-variant/10">
          <h2 class="font-[family-name:var(--font-headline)] text-2xl">Order Summary</h2>
        </div>

        <div class="px-8 py-6 space-y-4">
          <div id="summary-items" class="space-y-3 pb-4 border-b border-outline-variant/10"></div>

          <div class="space-y-3 py-2">
            <div class="flex justify-between items-center text-sm">
              <span class="text-outline uppercase tracking-widest text-xs">Subtotal</span>
              <span id="sum-subtotal" class="font-[family-name:var(--font-headline)]">Rp 0</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-outline uppercase tracking-widest text-xs">Shipping</span>
              <span class="text-xs font-medium text-on-surface">Complimentary</span>
            </div>
            <div class="flex justify-between items-center text-sm">
              <span class="text-outline uppercase tracking-widest text-xs">PPN (11%)</span>
              <span id="sum-tax" class="font-[family-name:var(--font-headline)]">Rp 0</span>
            </div>
          </div>

          <div class="flex justify-between items-center border-t border-outline-variant/10 pt-5">
            <span class="text-sm uppercase tracking-[0.2em] font-medium">Total</span>
            <span id="sum-total" class="font-[family-name:var(--font-headline)] text-2xl text-primary-container">Rp 0</span>
          </div>
        </div>

        <div class="px-8 pb-8 space-y-3">
          <a href="/checkout" class="block w-full burnished-gradient text-on-primary py-5 text-[11px] uppercase tracking-[0.3em] font-bold text-center hover:brightness-110 transition-all">
            Proceed to Checkout
          </a>
          <div class="pt-4 space-y-3">
            <div class="flex items-center gap-3 text-[10px] text-outline uppercase tracking-widest">
              <span class="material-symbols-outlined text-base text-primary-container">verified_user</span>
              Secure payment processing
            </div>
            <div class="flex items-center gap-3 text-[10px] text-outline uppercase tracking-widest">
              <span class="material-symbols-outlined text-base text-primary-container">local_shipping</span>
              Free shipping across Indonesia
            </div>
            <div class="flex items-center gap-3 text-[10px] text-outline uppercase tracking-widest">
              <span class="material-symbols-outlined text-base text-primary-container">replay</span>
              30-day hassle-free returns
            </div>
          </div>
        </div>
      </div>
    </aside>
  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot', { pageScript: '/js/cart-page.js' }) %>
