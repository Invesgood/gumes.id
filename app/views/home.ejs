<%- include('partials/head', { title: title }) %>
<%- include('partials/navbar') %>

<script id="products-data" type="application/json"><%- JSON.stringify(products).replace(/<\//g, "<\\/") %></script>
<main class="min-h-screen bg-surface flex-grow pt-56" id="catalog-root">

  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 mb-16 flex flex-col items-center text-center">
    <p class="text-primary text-xs tracking-[0.3em] uppercase mb-3">Handcrafted in Indonesia</p>
    <h1 class="font-[family-name:var(--font-headline)] text-5xl md:text-6xl text-on-surface mb-4 tracking-tighter">
      The Footwear Collection
    </h1>
    <p class="text-outline max-w-lg mx-auto text-lg">
      Curated leather goods, meticulously handcrafted for the discerning aesthetic. Every stitch tells a story of heritage and precision.
    </p>
  </div>

  <div class="max-w-screen-2xl mx-auto px-6 md:px-12 flex gap-16">

    <!-- Sidebar (desktop) -->
    <aside class="hidden lg:block w-56 shrink-0">
      <div class="sticky top-56">
        <!-- Kategori -->
        <div class="mb-8">
          <h3 class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-on-surface-variant mb-4">Kategori</h3>
          <ul class="space-y-3" data-filter-group="category">
            <% ['Semua', 'Sendal', 'Sepatu'].forEach(function(cat){ %>
              <li>
                <button type="button" data-value="<%= cat %>"
                  class="filter-cat text-sm text-left w-full transition-colors text-on-surface-variant hover:text-primary">
                  <%= cat %>
                </button>
              </li>
            <% }); %>
          </ul>
        </div>

        <!-- Warna -->
        <div class="mb-8">
          <h3 class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-on-surface-variant mb-4">Warna</h3>
          <div class="space-y-2.5" data-filter-group="color">
            <% [{id:'hitam',label:'Hitam',hex:'#1a1a1a'},{id:'coklat',label:'Coklat',hex:'#5d4037'},{id:'tan',label:'Tan',hex:'#c68642'}].forEach(function(c){ %>
              <button type="button" data-value="<%= c.id %>" class="filter-color flex items-center gap-3 w-full group">
                <span class="filter-color-dot w-5 h-5 rounded-full border-2 border-transparent transition-all" style="background-color: <%= c.hex %>"></span>
                <span class="filter-color-label text-sm transition-colors text-on-surface-variant group-hover:text-primary"><%= c.label %></span>
                <span class="filter-color-check material-symbols-outlined text-primary-container text-base ml-auto hidden">check</span>
              </button>
            <% }); %>
            <button type="button" id="filter-color-clear"
              class="text-[10px] uppercase tracking-widest text-outline hover:text-error transition-colors mt-1 hidden">
              Hapus filter
            </button>
          </div>
        </div>

        <!-- Urutkan -->
        <div class="mb-8">
          <h3 class="text-[10px] font-extrabold uppercase tracking-[0.2em] text-on-surface-variant mb-4">Urutkan</h3>
          <ul class="space-y-3" data-filter-group="sort">
            <% [{id:'default',label:'Default'},{id:'low-high',label:'Harga: Terendah'},{id:'high-low',label:'Harga: Tertinggi'},{id:'bestseller',label:'Best Seller'}].forEach(function(s){ %>
              <li>
                <button type="button" data-value="<%= s.id %>" class="filter-sort text-sm text-left w-full transition-colors text-on-surface-variant hover:text-primary">
                  <%= s.label %>
                </button>
              </li>
            <% }); %>
          </ul>
        </div>

        <div class="pt-5 border-t border-outline-variant/20">
          <p class="text-xs leading-relaxed text-outline">
            <span id="result-count"><%= products.length %></span> produk ditemukan
          </p>
        </div>
      </div>
    </aside>

    <!-- Grid -->
    <section class="flex-grow pb-32">
      <!-- Mobile filters -->
      <div class="flex gap-2 overflow-x-auto pb-3 mb-3 lg:hidden" data-filter-group="category-mobile">
        <% ['Semua','Sendal','Sepatu'].forEach(function(cat){ %>
          <button type="button" data-value="<%= cat %>"
            class="filter-cat-m shrink-0 text-[10px] font-bold tracking-widest uppercase px-4 py-2 border border-outline-variant text-on-surface-variant transition-colors">
            <%= cat %>
          </button>
        <% }); %>
      </div>
      <div class="flex gap-2 overflow-x-auto pb-3 mb-3 lg:hidden" data-filter-group="color-mobile">
        <% [{id:'hitam',label:'Hitam',hex:'#1a1a1a'},{id:'coklat',label:'Coklat',hex:'#5d4037'},{id:'tan',label:'Tan',hex:'#c68642'}].forEach(function(c){ %>
          <button type="button" data-value="<%= c.id %>"
            class="filter-color-m shrink-0 flex items-center gap-2 text-[10px] font-bold tracking-widest uppercase px-3 py-2 border border-outline-variant text-on-surface-variant transition-colors">
            <span class="w-3 h-3 rounded-full" style="background-color: <%= c.hex %>"></span>
            <%= c.label %>
          </button>
        <% }); %>
      </div>

      <div class="flex items-center justify-between mb-8 flex-wrap gap-3">
        <p class="text-xs text-outline uppercase tracking-widest">
          <span id="result-count-top"><%= products.length %></span> produk
        </p>
        <div class="flex items-center gap-2 flex-wrap" data-filter-group="sort-pill">
          <% [{id:'low-high',label:'Harga: Terendah',icon:'arrow_upward'},{id:'high-low',label:'Harga: Tertinggi',icon:'arrow_downward'},{id:'bestseller',label:'Best Seller',icon:'star'}].forEach(function(s){ %>
            <button type="button" data-value="<%= s.id %>"
              class="filter-sort-pill text-[10px] font-bold uppercase tracking-widest px-4 py-2 border border-outline-variant text-on-surface-variant hover:border-on-surface transition-colors flex items-center gap-1.5">
              <span class="material-symbols-outlined text-base"><%= s.icon %></span>
              <%= s.label %>
            </button>
          <% }); %>
        </div>
      </div>

      <div id="product-grid" class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-10 md:gap-x-8 md:gap-y-20"></div>

      <div id="empty-state" class="hidden flex-col items-center justify-center py-32 text-center">
        <span class="material-symbols-outlined text-outline-variant mb-4" style="font-size: 48px;">search_off</span>
        <p class="text-on-surface-variant mb-2">Tidak ada produk ditemukan</p>
        <button type="button" id="reset-filters" class="text-[11px] uppercase tracking-widest text-primary-container border-b border-primary-container mt-2">
          Reset filter
        </button>
      </div>
    </section>
  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot', { pageScript: '/js/catalog.js' }) %>
