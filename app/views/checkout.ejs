<%- include('partials/head', { title: title }) %>
<%- include('partials/navbar') %>

<main class="pt-48 pb-24 px-6 md:px-12 max-w-7xl mx-auto min-h-screen">
  <form id="checkout-form" class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">

    <div class="lg:col-span-7 space-y-16">
      <div>
        <p class="text-primary text-xs tracking-[0.3em] uppercase mb-3">Checkout</p>
        <h1 class="font-[family-name:var(--font-headline)] text-4xl md:text-5xl font-light tracking-tight mb-3">Shipping Information</h1>
        <p class="text-outline text-sm">Lengkapi data pengiriman untuk melanjutkan ke pembayaran.</p>
      </div>

      <div class="space-y-5">
        <div>
          <label class="text-[11px] uppercase tracking-widest text-outline">Nama Lengkap</label>
          <input type="text" name="name" required class="mt-2 w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary-container" />
        </div>
        <div>
          <label class="text-[11px] uppercase tracking-widest text-outline">Email</label>
          <input type="email" name="email" required class="mt-2 w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary-container" />
        </div>
        <div>
          <label class="text-[11px] uppercase tracking-widest text-outline">Alamat Lengkap</label>
          <input type="text" name="address" required class="mt-2 w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary-container" />
        </div>
        <div class="grid grid-cols-2 gap-5">
          <div>
            <label class="text-[11px] uppercase tracking-widest text-outline">Kota</label>
            <input type="text" name="city" required class="mt-2 w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary-container" />
          </div>
          <div>
            <label class="text-[11px] uppercase tracking-widest text-outline">Kode Pos</label>
            <input type="text" name="postal" required class="mt-2 w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary-container" />
          </div>
        </div>
      </div>

      <div id="checkout-error" class="hidden text-error text-sm border border-error/30 bg-error-container/20 px-4 py-3"></div>
    </div>

    <aside class="lg:col-span-5 lg:sticky lg:top-48 bg-surface-container-lowest border border-outline-variant/30 shadow-md">
      <div class="px-8 pt-8 pb-6 border-b border-outline-variant/10">
        <h2 class="font-[family-name:var(--font-headline)] text-2xl">Order Summary</h2>
      </div>
      <div class="px-8 py-6 space-y-4">
        <div id="co-items" class="space-y-3 pb-4 border-b border-outline-variant/10"></div>
        <div class="space-y-3 py-2">
          <div class="flex justify-between text-sm">
            <span class="text-outline uppercase tracking-widest text-xs">Subtotal</span>
            <span id="co-subtotal">Rp 0</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-outline uppercase tracking-widest text-xs">Shipping</span>
            <span class="text-xs">Complimentary</span>
          </div>
          <div class="flex justify-between text-sm">
            <span class="text-outline uppercase tracking-widest text-xs">PPN (11%)</span>
            <span id="co-tax">Rp 0</span>
          </div>
        </div>
        <div class="flex justify-between items-center border-t border-outline-variant/10 pt-5">
          <span class="text-sm uppercase tracking-[0.2em] font-medium">Total</span>
          <span id="co-total" class="font-[family-name:var(--font-headline)] text-2xl text-primary-container">Rp 0</span>
        </div>
      </div>
      <div class="px-8 pb-8">
        <button type="submit" id="co-submit"
          class="w-full burnished-gradient text-on-primary py-5 text-[11px] uppercase tracking-[0.3em] font-bold hover:brightness-110 transition-all disabled:opacity-50">
          <span id="co-submit-label">Place Order</span>
        </button>
        <p class="text-[10px] text-outline uppercase tracking-widest mt-4 text-center">
          <span class="material-symbols-outlined text-base align-middle text-primary-container">lock</span>
          Payment akan diproses di langkah berikutnya
        </p>
      </div>
    </aside>
  </form>

  <div id="empty-cart-redirect" class="hidden text-center py-32">
    <p class="text-on-surface-variant mb-4">Cart kosong. Tambahkan produk dulu.</p>
    <a href="/" class="text-[11px] uppercase tracking-widest text-primary-container border-b border-primary-container">Browse Collection</a>
  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot', { pageScript: '/js/checkout.js' }) %>
