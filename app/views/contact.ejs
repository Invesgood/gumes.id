<%- include('partials/head', { title: title }) %>
<%- include('partials/navbar') %>

<main class="flex-grow max-w-screen-2xl mx-auto px-6 md:px-12 py-16 md:py-24 pt-56 md:pt-64 w-full bg-surface">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-12 md:gap-16 items-start">

    <!-- ── Editorial Intro ── -->
    <div class="md:col-span-5 space-y-12">
      <div>
        <h2 class="text-xs uppercase tracking-[0.3em] text-primary mb-6">Inquiry &amp; Dialogue</h2>
        <h1 class="font-[family-name:var(--font-headline)] text-5xl md:text-7xl lg:text-8xl leading-[0.95] tracking-tighter text-on-surface">
          The Art of<br />
          Bespoke<br />
          <span class="italic text-primary-container">Connection.</span>
        </h1>
      </div>
      <p class="text-base md:text-lg leading-relaxed opacity-80 max-w-md">
        Baik Anda mencari commission tunggal maupun memiliki pertanyaan mengenai koleksi terbaru kami, para kurator siap membantu dengan presisi profesional.
      </p>
      <div class="space-y-8 pt-4">
        <div class="flex flex-col gap-1">
          <span class="text-[10px] uppercase tracking-widest opacity-40">Direct Communication</span>
          <a href="mailto:concierge@gumes.id" class="font-[family-name:var(--font-headline)] text-lg md:text-xl hover:text-primary transition-colors">
            concierge@gumes.id
          </a>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[10px] uppercase tracking-widest opacity-40">The Atelier</span>
          <span class="font-[family-name:var(--font-headline)] text-lg md:text-xl leading-tight">
            Jl. Pemuda Raya No. 88<br />
            Rawamangun, Jakarta Timur 13220
          </span>
        </div>
        <div class="flex flex-col gap-1">
          <span class="text-[10px] uppercase tracking-widest opacity-40">Telepon</span>
          <a href="tel:+62214788123" class="font-[family-name:var(--font-headline)] text-lg md:text-xl hover:text-primary transition-colors">
            +62 21 4788 1234
          </a>
        </div>
        <div class="flex gap-6 pt-4">
          <a href="#" aria-label="Instagram" class="text-primary hover:opacity-70 transition-opacity">
            <span class="material-symbols-outlined text-2xl">photo_camera</span>
          </a>
          <a href="#" aria-label="TikTok" class="text-primary hover:opacity-70 transition-opacity">
            <span class="material-symbols-outlined text-2xl">movie</span>
          </a>
          <a href="/" aria-label="Shop" class="text-primary hover:opacity-70 transition-opacity">
            <span class="material-symbols-outlined text-2xl">shopping_bag</span>
          </a>
        </div>
      </div>
      <div class="w-full h-64 md:h-80 bg-secondary-container overflow-hidden relative">
        <img
          src="/images/1777106834777.webp"
          alt="Leather workshop"
          class="absolute inset-0 w-full h-full object-cover mix-blend-multiply opacity-80 grayscale hover:grayscale-0 transition-all duration-700"
        />
      </div>
    </div>

    <!-- ── Contact Form ── -->
    <div class="md:col-span-7 bg-surface-container-high p-8 md:p-12 lg:p-20 relative">
      <div class="absolute -top-4 -left-4 w-24 h-24 border-t border-l border-primary opacity-30"></div>

      <form id="contact-form" class="space-y-10 md:space-y-12" novalidate>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10 md:gap-y-12">
          <div>
            <label for="cf-name" class="block text-[10px] uppercase tracking-widest text-primary mb-2">Full Identity</label>
            <input
              id="cf-name"
              name="name"
              type="text"
              required
              maxlength="200"
              placeholder="NAMA LENGKAP"
              class="w-full bg-transparent border-0 border-b border-outline focus:outline-none focus:border-primary py-2 px-0 transition-colors placeholder:opacity-30"
            />
          </div>
          <div>
            <label for="cf-email" class="block text-[10px] uppercase tracking-widest text-primary mb-2">Electronic Mail</label>
            <input
              id="cf-email"
              name="email"
              type="email"
              required
              maxlength="200"
              placeholder="EMAIL@CONTOH.COM"
              class="w-full bg-transparent border-0 border-b border-outline focus:outline-none focus:border-primary py-2 px-0 transition-colors placeholder:opacity-30"
            />
          </div>
        </div>
        <div>
          <label for="cf-inquiry" class="block text-[10px] uppercase tracking-widest text-primary mb-2">Nature of Inquiry</label>
          <select
            id="cf-inquiry"
            name="inquiry"
            class="w-full bg-transparent border-0 border-b border-outline focus:outline-none focus:border-primary py-2 px-0 transition-colors appearance-none cursor-pointer"
          >
            <option>Bespoke Leather Commission</option>
            <option>Order Acquisition Inquiry</option>
            <option>Press &amp; Editorial</option>
            <option>Architectural Collaboration</option>
            <option>Lainnya</option>
          </select>
        </div>
        <div>
          <label for="cf-message" class="block text-[10px] uppercase tracking-widest text-primary mb-2">Your Message</label>
          <textarea
            id="cf-message"
            name="message"
            required
            maxlength="5000"
            rows="4"
            placeholder="CERITAKAN VISI ATAU KEBUTUHAN ANDA…"
            class="w-full bg-transparent border-0 border-b border-outline focus:outline-none focus:border-primary py-2 px-0 transition-colors resize-none placeholder:opacity-30"
          ></textarea>
        </div>

        <div id="cf-feedback" class="text-xs tracking-wide hidden"></div>

        <div class="pt-4 md:pt-8">
          <button
            type="submit"
            id="cf-submit"
            class="burnished-gradient w-full py-5 text-on-primary text-sm font-bold uppercase tracking-[0.2em] hover:brightness-110 active:scale-[0.98] transition-all flex items-center justify-center gap-3 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span id="cf-submit-label">Initiate Correspondence</span>
            <span class="material-symbols-outlined text-lg">arrow_right_alt</span>
          </button>
        </div>
      </form>
    </div>

  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot', { pageScript: '/js/contact.js' }) %>
