<%- include('partials/head', { title: title }) %>
<%- include('partials/navbar') %>

<script id="products-data" type="application/json"><%- JSON.stringify(products).replace(/<\//g, "<\\/") %></script>

<main class="min-h-screen bg-surface flex-grow pt-56" id="catalog-root">

  <!-- ── Hero ── -->
  <section class="relative h-[80vh] flex items-end pb-20 px-6 md:px-16 overflow-hidden">
    <div class="absolute inset-0 z-0">
      <img
        src="/images/1777106834791.webp"
        alt="New arrivals hero"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20"></div>
    </div>

    <div class="relative z-10 w-full max-w-screen-2xl mx-auto flex flex-col md:flex-row md:items-end md:justify-between gap-8">
      <div>
        <p class="text-[#e9c176] text-xs tracking-[0.35em] uppercase mb-4">
          The Artisan Collection — SS 2026
        </p>
        <h1 class="font-[family-name:var(--font-headline)] text-white text-5xl md:text-7xl leading-none mb-2">
          New<br />
          <span class="italic text-[#e9c176]">Arrivals</span>
        </h1>
        <p class="text-white/70 text-sm mt-4 max-w-xs leading-relaxed">
          Koleksi terbaru — setiap pasang dibentuk dari satu lembar kulit utuh, dirajut dalam 120 jam kerja.
        </p>
      </div>
      <a
        href="#collection"
        class="inline-flex items-center gap-3 burnished-gradient text-on-primary text-[11px] font-bold tracking-widest uppercase px-10 py-5 hover:brightness-110 transition-all self-end md:self-auto"
      >
        Discover Collection
        <span class="material-symbols-outlined text-base">arrow_downward</span>
      </a>
    </div>
  </section>

  <!-- ── Intro strip ── -->
  <div class="bg-surface-container border-y border-outline-variant/20 py-6">
    <div class="max-w-screen-2xl mx-auto px-6 md:px-16 flex flex-wrap gap-6 md:gap-8 items-center justify-between">
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary-container text-xl">verified</span>
        <span class="text-[10px] md:text-xs tracking-widest uppercase text-on-surface-variant">Hand-crafted di Indonesia</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary-container text-xl">schedule</span>
        <span class="text-[10px] md:text-xs tracking-widest uppercase text-on-surface-variant">120+ Jam per Pasang</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary-container text-xl">local_shipping</span>
        <span class="text-[10px] md:text-xs tracking-widest uppercase text-on-surface-variant">Gratis Ongkir</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="material-symbols-outlined text-primary-container text-xl">replay</span>
        <span class="text-[10px] md:text-xs tracking-widest uppercase text-on-surface-variant">30 Hari Garansi</span>
      </div>
    </div>
  </div>

  <!-- ── Product Grid ── -->
  <section id="collection" class="max-w-screen-2xl mx-auto px-6 md:px-16 pt-20 md:pt-24 pb-24 md:pb-32">
    <div class="flex items-end justify-between mb-12 md:mb-16 flex-wrap gap-4">
      <div>
        <p class="text-primary text-xs tracking-[0.3em] uppercase mb-2">Just Landed</p>
        <h2 class="font-[family-name:var(--font-headline)] text-4xl md:text-5xl">
          The New Legacy
        </h2>
      </div>
      <p class="text-outline text-sm">
        <span id="result-count-top"><%= products.length %></span> koleksi baru
      </p>
    </div>

    <div id="product-grid" class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-x-4 gap-y-10 md:gap-x-8 md:gap-y-20"></div>

    <div id="empty-state" class="hidden flex-col items-center justify-center py-32 text-center">
      <span class="material-symbols-outlined text-outline-variant mb-4" style="font-size: 48px;">search_off</span>
      <p class="text-on-surface-variant mb-2">Belum ada produk baru</p>
      <a href="/" class="text-[11px] uppercase tracking-widest text-primary-container border-b border-primary-container mt-2">
        Lihat semua koleksi
      </a>
    </div>
  </section>

  <!-- ── Editorial ── -->
  <section class="bg-surface-container py-20 md:py-32">
    <div class="max-w-screen-xl mx-auto px-6 md:px-16 grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24 items-center">
      <div class="relative aspect-square">
        <div class="absolute -top-8 -left-8 w-40 h-40 burnished-gradient opacity-10 blur-3xl"></div>
        <img
          src="/images/1777106834777.webp"
          alt="Leather texture detail"
          class="absolute inset-0 w-full h-full object-cover"
        />
      </div>
      <div>
        <p class="text-primary text-xs tracking-[0.3em] uppercase mb-4">
          The Philosophy of Form
        </p>
        <h2 class="font-[family-name:var(--font-headline)] text-4xl md:text-5xl mb-6 leading-tight">
          Unrivaled<br />
          <span class="italic">Materiality</span>
        </h2>
        <p class="text-on-surface-variant leading-relaxed mb-6">
          Setiap karya GUMES dimulai dari satu lembar kulit premium dari penyamak keluarga.
          Proses burnishing — lapisan lilin dan pigmen yang dikerjakan langsung dengan tangan —
          menghasilkan kedalaman warna yang tidak bisa ditiru mesin.
        </p>
        <p class="text-on-surface-variant leading-relaxed mb-10">
          Seiring waktu, kulit membentuk patina yang unik sesuai perjalanan Anda.
          Inilah tanda tangan dari Digital Curator, dan hanya milik Anda.
        </p>
        <div class="flex gap-8 md:gap-12 mb-10">
          <div>
            <p class="font-[family-name:var(--font-headline)] text-primary text-3xl mb-1">120+</p>
            <p class="text-[10px] tracking-widest text-outline uppercase">Jam per pasang</p>
          </div>
          <div>
            <p class="font-[family-name:var(--font-headline)] text-primary text-3xl mb-1">100%</p>
            <p class="text-[10px] tracking-widest text-outline uppercase">Hand-cut leather</p>
          </div>
          <div>
            <p class="font-[family-name:var(--font-headline)] text-primary text-3xl mb-1">1 of 1</p>
            <p class="text-[10px] tracking-widest text-outline uppercase">Unique patina</p>
          </div>
        </div>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 text-xs tracking-widest uppercase font-bold border-b border-on-surface pb-1 hover:text-primary hover:border-primary transition-colors"
        >
          Bicara dengan artisan kami
          <span class="material-symbols-outlined text-base">arrow_forward</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── Atelier CTA ── -->
  <section class="py-20 md:py-40 px-6 md:px-16 text-center">
    <p class="text-primary text-xs tracking-[0.3em] uppercase mb-4">Visit the Atelier</p>
    <h2 class="font-[family-name:var(--font-headline)] text-4xl md:text-6xl mb-12">
      Where Tradition <span class="italic">Breaks</span> Ground
    </h2>
    <div class="max-w-4xl mx-auto h-[420px] relative overflow-hidden group">
      <img
        src="/images/1777106834770.webp"
        alt="Atelier interior"
        class="absolute inset-0 w-full h-full object-cover opacity-50 group-hover:scale-105 transition-transform duration-[2000ms]"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="bg-surface-container-lowest/90 backdrop-blur-md p-8 md:p-10 max-w-sm w-full mx-4">
          <p class="font-[family-name:var(--font-headline)] text-2xl mb-1">Grand Atelier, Jakarta</p>
          <p class="text-xs tracking-widest text-outline uppercase mb-2">Jl. Kemang Raya No. 15</p>
          <p class="text-xs text-on-surface-variant mb-6">Buka setiap hari · 10.00 – 20.00 WIB</p>
          <a
            href="/location"
            class="block w-full burnished-gradient text-on-primary text-center text-[11px] font-bold tracking-[0.2em] uppercase py-4 hover:brightness-110 transition-all mb-3"
          >
            Get Directions
          </a>
          <a
            href="/contact"
            class="block w-full border border-outline-variant py-4 text-[11px] tracking-[0.2em] uppercase text-center hover:bg-on-surface hover:text-surface hover:border-on-surface transition-colors"
          >
            Book a Private View
          </a>
        </div>
      </div>
    </div>
  </section>

</main>

<%- include('partials/footer') %>
<%- include('partials/foot', { pageScript: '/js/catalog.js' }) %>
