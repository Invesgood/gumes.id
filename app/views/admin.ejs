<%- include('partials/head', { title: title }) %>
<%- include('partials/navbar') %>

<script id="products-data" type="application/json"><%- JSON.stringify(products).replace(/<\//g, "<\\/") %></script>
<script id="reviews-data" type="application/json"><%- JSON.stringify(reviews).replace(/<\//g, "<\\/") %></script>

<main class="pt-48 pb-24 px-6 md:px-12 max-w-7xl mx-auto min-h-screen">
  <div id="toast" class="hidden fixed top-6 right-6 z-50 px-6 py-4 text-sm font-medium shadow-lg"></div>

  <header class="mb-12 flex flex-wrap items-end justify-between gap-4">
    <div>
      <p class="text-primary text-xs tracking-[0.3em] uppercase mb-3">Admin Panel</p>
      <h1 class="font-[family-name:var(--font-headline)] text-4xl md:text-5xl font-light tracking-tight">Manage Atelier</h1>
      <p class="text-sm text-outline mt-2"><%= products.length %> produk · <%= reviews.length %> ulasan</p>
    </div>
    <div class="flex gap-2">
      <button type="button" id="tab-products" class="admin-tab px-5 py-2.5 text-[11px] font-bold uppercase tracking-widest bg-on-surface text-surface border border-on-surface transition-all">
        Produk
      </button>
      <button type="button" id="tab-reviews" class="admin-tab px-5 py-2.5 text-[11px] font-bold uppercase tracking-widest border border-outline-variant text-on-surface-variant hover:border-on-surface transition-all">
        Ulasan
      </button>
    </div>
  </header>

  <!-- Products tab -->
  <section id="panel-products">
    <div class="flex justify-end mb-6">
      <button type="button" id="add-product"
        class="burnished-gradient text-on-primary px-6 py-3 text-[11px] font-bold uppercase tracking-widest hover:brightness-110 transition-all flex items-center gap-2">
        <span class="material-symbols-outlined text-base">add</span>
        Tambah Produk
      </button>
    </div>

    <div id="product-list" class="space-y-3"></div>
  </section>

  <!-- Reviews tab -->
  <section id="panel-reviews" class="hidden">
    <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
      <p class="text-xs text-outline uppercase tracking-widest">Filter:</p>
      <div class="flex gap-2 flex-wrap" id="review-filter">
        <% ['Semua', 'Sendal', 'Sepatu'].forEach(function(cat){ %>
          <button type="button" data-cat="<%= cat %>"
            class="review-filter-btn px-4 py-2 text-[10px] font-bold uppercase tracking-widest border border-outline-variant text-on-surface-variant transition-colors">
            <%= cat %>
          </button>
        <% }); %>
      </div>
    </div>
    <div id="review-list" class="space-y-3"></div>
  </section>

  <!-- Product form modal -->
  <div id="product-modal" class="hidden fixed inset-0 z-50 bg-black/50 flex items-start justify-center p-4 pt-12 overflow-y-auto">
    <div class="bg-surface-container-lowest max-w-3xl w-full p-8 md:p-10 shadow-2xl border border-outline-variant/30">
      <div class="flex items-start justify-between mb-6">
        <div>
          <p class="text-primary text-[11px] tracking-widest uppercase mb-1" id="form-title-tag">Produk Baru</p>
          <h3 class="font-[family-name:var(--font-headline)] text-2xl" id="form-title">Tambah Produk</h3>
        </div>
        <button type="button" id="form-close" class="text-outline hover:text-on-surface">
          <span class="material-symbols-outlined">close</span>
        </button>
      </div>

      <form id="product-form" class="space-y-6">
        <input type="hidden" name="id" id="form-id" />

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-outline mb-2">Nama Produk</label>
            <input name="name" required class="w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-outline mb-2">Material</label>
            <input name="material" class="w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-outline mb-2">Harga (Rp, angka)</label>
            <input name="priceNum" type="number" min="0" required class="w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary" />
          </div>
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-outline mb-2">Kategori</label>
            <select name="category" required class="w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary">
              <option value="Sendal">Sendal</option>
              <option value="Sepatu">Sepatu</option>
            </select>
          </div>
        </div>

        <div>
          <label class="block text-[10px] uppercase tracking-widest text-outline mb-2">Deskripsi</label>
          <textarea name="description" rows="3" class="w-full bg-transparent border border-outline-variant px-3 py-2 focus:outline-none focus:border-primary resize-none"></textarea>
        </div>

        <div>
          <label class="block text-[10px] uppercase tracking-widest text-outline mb-3">Warna Tersedia</label>
          <div class="flex gap-2 flex-wrap" id="color-chips">
            <% [{id:'hitam',label:'Hitam',hex:'#1a1a1a'},{id:'coklat',label:'Coklat',hex:'#5d4037'},{id:'tan',label:'Tan',hex:'#c68642'}].forEach(function(c){ %>
              <button type="button" data-color="<%= c.id %>"
                class="color-chip flex items-center gap-2 px-3 py-2 border-2 border-outline-variant text-on-surface-variant transition-all text-[11px] font-bold uppercase tracking-widest">
                <span class="w-4 h-4 rounded-full" style="background-color:<%= c.hex %>"></span>
                <%= c.label %>
              </button>
            <% }); %>
          </div>
        </div>

        <div>
          <label class="block text-[10px] uppercase tracking-widest text-outline mb-3">Gambar Utama</label>
          <div class="flex items-center gap-4">
            <label class="cursor-pointer border-2 border-dashed border-outline-variant px-6 py-4 hover:border-primary transition-colors flex items-center gap-2 text-xs">
              <span class="material-symbols-outlined text-base">upload_file</span>
              <span id="main-img-label">Pilih file…</span>
              <input type="file" accept="image/*" id="main-image-input" class="hidden" />
            </label>
            <img id="main-image-preview" src="" class="w-20 h-20 object-cover border border-outline-variant/30 hidden" />
          </div>
          <input type="hidden" name="image" id="main-image-url" />
        </div>

        <div id="color-image-section" class="hidden">
          <label class="block text-[10px] uppercase tracking-widest text-outline mb-3">Gambar per Warna (opsional)</label>
          <div class="space-y-3" id="color-image-list"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-[10px] uppercase tracking-widest text-outline mb-2">Badge (opsional)</label>
            <input name="badge" class="w-full bg-transparent border-b border-outline-variant py-2 focus:outline-none focus:border-primary" placeholder="Limited, Hand-stitched, dll" />
          </div>
          <div class="flex flex-col gap-2 pt-2">
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" name="isNewArrival" class="accent-primary" />
              <span>New Arrival</span>
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" name="bestSeller" class="accent-primary" />
              <span>Best Seller</span>
            </label>
            <label class="flex items-center gap-2 text-sm cursor-pointer">
              <input type="checkbox" name="featured" class="accent-primary" />
              <span>Featured</span>
            </label>
          </div>
        </div>

        <div id="form-error" class="hidden text-error text-sm border border-error/30 px-3 py-2"></div>

        <div class="flex justify-end gap-3 pt-4 border-t border-outline-variant/20">
          <button type="button" id="form-cancel" class="px-6 py-3 text-[11px] font-bold uppercase tracking-widest border border-outline-variant text-on-surface-variant hover:bg-surface-container transition-colors">
            Batal
          </button>
          <button type="submit" id="form-save" class="burnished-gradient text-on-primary px-8 py-3 text-[11px] font-bold uppercase tracking-widest hover:brightness-110 transition-all disabled:opacity-60">
            <span id="form-save-label">Simpan</span>
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Delete confirm -->
  <div id="delete-modal" class="hidden fixed inset-0 z-50 bg-black/50 flex items-center justify-center p-4">
    <div class="bg-surface-container-lowest max-w-md w-full p-8 shadow-2xl border border-outline-variant/30">
      <div class="flex items-center gap-3 mb-4">
        <span class="material-symbols-outlined text-error text-3xl">delete_forever</span>
        <h3 class="font-[family-name:var(--font-headline)] text-xl">Hapus produk?</h3>
      </div>
      <p class="text-sm text-on-surface-variant mb-6" id="delete-msg">Aksi ini tidak bisa di-undo.</p>
      <div class="flex justify-end gap-3">
        <button type="button" id="delete-cancel" class="px-5 py-2.5 text-[11px] font-bold uppercase tracking-widest border border-outline-variant">Batal</button>
        <button type="button" id="delete-confirm" class="px-5 py-2.5 text-[11px] font-bold uppercase tracking-widest bg-error text-on-error">Hapus</button>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>
<%- include('partials/foot', { pageScript: '/js/admin.js' }) %>
